#!/usr/bin/env bash
# Blocks sensitive paths from leaving this checkout, even if pre-commit was bypassed.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
guard="$repo_root/scripts/sensitive-file-guard.sh"
zero_sha="0000000000000000000000000000000000000000"
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue

  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    if ! "$guard" --ref "$local_sha"; then
      blocked=1
    fi
  elif ! git cat-file -e "$remote_sha^{commit}" 2>/dev/null; then
    if ! "$guard" --ref "$local_sha"; then
      blocked=1
    fi
  else
    if ! "$guard" --range "$remote_sha..$local_sha"; then
      blocked=1
    fi
  fi
done

exit "$blocked"
