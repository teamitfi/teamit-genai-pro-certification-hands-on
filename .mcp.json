{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "crm": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "tsx",
        "mcp/crm-server.ts"
      ],
      "env": {}
    }
  }
}