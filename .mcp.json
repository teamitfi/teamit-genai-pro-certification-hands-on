{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "env": {}
    },
    "crm": {
      "type": "stdio",
      "command": "go",
      "args": [
        "run",
        "./mcp"
      ],
      "env": {
        "CRM_API_BASE_URL": "http://localhost:3000"
      }
    }
  }
}
